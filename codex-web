#!/usr/bin/env node
'use strict';

/*
 * codex-web
 * Local Web UI for Codex app-server prompt queueing.
 * Browser assets are loaded from ./www next to this executable.
 * Runtime dependencies: Node.js built-ins only.
 */

const { parseArgs } = require('./src/cli');
const { CodexLimitWatchApp } = require('./src/app');

async function main() {
  const opts = parseArgs(process.argv.slice(2));
  const app = new CodexLimitWatchApp(opts);
  let forceShutdownUntil = 0;
  function requestShutdown(signal) {
    if (app.hasActivePrompt && app.hasActivePrompt()) {
      const now = Date.now();
      if (now < forceShutdownUntil) {
        app.shutdown(`${signal} forced`);
        return;
      }
      forceShutdownUntil = now + 5000;
      const keyName = signal === 'SIGINT' ? 'Ctrl+C' : signal;
      const message = `A prompt is running. Press ${keyName} again within 5 seconds to stop the server and interrupt it.`;
      console.error(message);
      if (app.appendOutput) app.appendOutput(message, 'system');
      setTimeout(() => {
        if (Date.now() >= forceShutdownUntil) forceShutdownUntil = 0;
      }, 5100).unref();
      return;
    }
    app.shutdown(signal);
  }
  process.on('SIGINT', () => requestShutdown('SIGINT'));
  process.on('SIGTERM', () => requestShutdown('SIGTERM'));
  process.on('uncaughtException', (err) => {
    console.error(err.stack || err.message || err);
    app.setError(err.message || String(err));
  });
  process.on('unhandledRejection', (err) => {
    console.error(err && err.stack || err);
    app.setError(err && err.message || String(err));
  });
  try { await app.start(); }
  catch (err) {
    console.error(err.message || String(err));
    process.exit(1);
  }
}

main();
